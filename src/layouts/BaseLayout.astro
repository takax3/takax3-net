---
import '../styles/global.css';

type Props = {
  title?: string;
  description?: string;
};

const {
  title = '恋ヶ窪タカノの実装室',
  description = '恋ヶ窪タカノ（taka）のポートフォリオ兼技術ブログ'
} = Astro.props;

const siteName = '恋ヶ窪タカノの実装室';
const pageTitle = title === siteName ? title : `${title} | ${siteName}`;

const footerLinks = [
  // URLが決まったものから `url` を追加してください。
  { title: 'X' },
  { title: 'Discord' },
  { title: 'GitHub' }
];
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <meta name="google-adsense-account" content="ca-pub-2541929274002492" />
    <meta name="theme-color" content="#FBF9F4" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#10182A" media="(prefers-color-scheme: dark)" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:FILL@0..1"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=M+PLUS+Rounded+1c:wght@500;700&family=Zen+Kaku+Gothic+New:wght@400;500;700&display=swap"
    />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <div class="site-header__inner">
          <a class="site-title" href="/">恋ヶ窪タカノの実装室</a>
          <button
            class="menu-toggle"
            type="button"
            aria-label="メニューを開く"
            aria-controls="site-nav"
            aria-expanded="false"
          >
            <span class="material-symbols-rounded" aria-hidden="true">menu</span>
          </button>
          <nav id="site-nav" class="site-nav" aria-label="Main navigation">
            <a href="/">Home</a>
            <a href="/about/">About</a>
            <a href="/projects/">Projects</a>
            <a href="/blog/">Blog</a>
          </nav>
        </div>
      </header>
      <main class="content">
        <slot />
      </main>
      <footer class="site-footer">
        <img
          class="footer-peek"
          src="/images/footer-peek.png"
          alt=""
          aria-hidden="true"
          width="312"
          height="312"
        />
        <div class="site-footer__inner">
          <small>&copy; {new Date().getFullYear()} 恋ヶ窪タカノの実装室</small>
          <nav class="footer-links" aria-label="External links">
            {
              footerLinks.map((link) =>
                'url' in link ? (
                  <a href={link.url} target="_blank" rel="noreferrer">
                    {link.title}
                  </a>
                ) : (
                  <span>{link.title}</span>
                )
              )
            }
          </nav>
        </div>
      </footer>
    </div>
    <script>
      const menuButton = document.querySelector<HTMLButtonElement>('.menu-toggle');
      const siteNav = document.querySelector<HTMLElement>('#site-nav');

      if (menuButton && siteNav) {
        const closeMenu = () => {
          menuButton.setAttribute('aria-expanded', 'false');
          menuButton.setAttribute('aria-label', 'メニューを開く');
          siteNav.dataset.open = 'false';
        };

        menuButton.addEventListener('click', () => {
          const isOpen = menuButton.getAttribute('aria-expanded') === 'true';

          menuButton.setAttribute('aria-expanded', String(!isOpen));
          menuButton.setAttribute('aria-label', isOpen ? 'メニューを開く' : 'メニューを閉じる');
          siteNav.dataset.open = String(!isOpen);
        });

        siteNav.querySelectorAll('a').forEach((link) => {
          link.addEventListener('click', closeMenu);
        });
      }
    </script>
  </body>
</html>
